# ===============================
# Backend (Go) environment
# ===============================

# Supabase Database connection
# Format: postgres://<user>:<password>@<host>:5432/<database>?sslmode=require
DATABASE_URL=postgres://your_user:your_password@your_project_host:5432/your_db?sslmode=require

# Optional: Backend server port (default: 8080)
PORT=8080

# ===============================
# Auth and token settings
# ===============================

# JWT signing secret (change in non-local environments)
JWT_SECRET=dev-secret-change-me

# JWT issuer claim
JWT_ISSUER=org-man-app

# Access token lifetime in minutes (used by Bearer-protected endpoints)
ACCESS_TOKEN_TTL_MINUTES=8

# Refresh token/session lifetime (currently interpreted as minutes by session manager)
REFRESH_TOKEN_TTL_HOURS=1

# Password policy and hashing
MIN_PASSWORD_LENGTH=12
BCRYPT_COST=12

# ===============================
# Rate limiting settings
# ===============================

RATE_LIMIT_RPS=10.0
RATE_LIMIT_BURST=20
